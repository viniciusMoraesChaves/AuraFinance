# =========================================================
# ARQUIVO DE CONFIGURAÇÃO DA API (EXEMPLO)
# =========================================================
# Este arquivo serve como modelo para configuração do projeto.
# Ele NÃO deve conter dados reais sensíveis.
#
# Cada membro do grupo deve:
# 1. Criar um arquivo chamado ".env" na raiz do backend
# 2. Copiar o conteúdo deste arquivo para o ".env"
# 3. Substituir os valores conforme necessário
#
# IMPORTANTE:
# O arquivo ".env" NÃO deve ser enviado para o GitHub.
# Ele está no .gitignore por segurança.
# =========================================================


# =========================================================
# JWT (AUTENTICAÇÃO)
# =========================================================
# Chave secreta usada para gerar e validar tokens JWT.
#
# Essa chave é utilizada no login (jwt.sign)
# e no middleware (jwt.verify).
#
# Para desenvolvimento, todos podem usar o mesmo valor.
# Em produção, essa chave deve ser forte e secreta.
# =========================================================

JWT_SECRET=aura_finance_dev_2026


# =========================================================
# BANCO DE DADOS (caso usem no futuro)
# =========================================================
# Descomente e configure quando necessário.
#
# DB_NAME=nome_do_banco
# DB_USER=usuario
# DB_PASSWORD=senha
# DB_HOST=localhost
# DB_PORT=3306
# =========================================================